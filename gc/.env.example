# RSI分层极值追踪量化交易系统环境变量配置模板
# 使用方法：复制此文件为.env并填入实际值

#################################################
# 1. 交易所API配置
#################################################

# OKX API配置
OKX_API_KEY=your_api_key_here                 # OKX API密钥
OKX_API_SECRET=your_api_secret_here           # OKX API密钥
OKX_API_PASSPHRASE=your_passphrase_here       # OKX API密码短语
OKX_API_URL=https://www.okx.com               # OKX API地址，国内可能需要代理
OKX_WS_PUBLIC_URL=wss://ws.okx.com:8443/ws/v5/public  # OKX公共WebSocket地址
OKX_WS_PRIVATE_URL=wss://ws.okx.com:8443/ws/v5/private  # OKX私有WebSocket地址

# 预留其他交易所API配置（未来扩展用）
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# HTX_API_KEY=
# HTX_API_SECRET=

#################################################
# 2. 数据库配置
#################################################

# TimescaleDB (PostgreSQL时序数据库)配置
POSTGRES_USER=postgres                        # 数据库用户名
POSTGRES_PASSWORD=your_secure_password        # 数据库密码
POSTGRES_DB=rsi_tracker                       # 数据库名称
POSTGRES_HOST=timescaledb                     # 数据库主机名（Docker内网络名）
POSTGRES_PORT=5432                            # 数据库端口
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# 数据保留策略（时序数据）
DATA_RETENTION_DAYS=7                         # K线数据保留天数
TRADE_LOG_RETENTION_DAYS=30                   # 交易日志保留天数

#################################################
# 3. Redis配置
#################################################

REDIS_HOST=redis                              # Redis主机名（Docker内网络名）
REDIS_PORT=6379                               # Redis端口
REDIS_DB=0                                    # Redis数据库索引
REDIS_PASSWORD=your_redis_password            # Redis密码（可选）
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

#################################################
# 4. 交易策略参数
#################################################

# RSI参数
RSI_PERIOD=14                                 # RSI计算周期

# 多头阈值
RSI_LONG_LEVEL1=35                            # 多头第一层阈值
RSI_LONG_LEVEL2=30                            # 多头第二层阈值
RSI_LONG_LEVEL3=20                            # 多头第三层阈值

# 空头阈值
RSI_SHORT_LEVEL1=65                           # 空头第一层阈值
RSI_SHORT_LEVEL2=70                           # 空头第二层阈值
RSI_SHORT_LEVEL3=80                           # 空头第三层阈值

# 极值回撤参数
RSI_RETRACEMENT_POINTS=2                      # 极值回撤触发点数

# 加仓参数
MAX_ADDITIONAL_POSITIONS=4                    # 最大加仓次数

# 止损参数
FIXED_STOP_LOSS_POINTS=6                      # 固定止损点数

# 止盈参数（分层）
PROFIT_TAKING_WINDOWS=5,10,15,30,40           # 持仓K线数分层窗口
PROFIT_RETRACEMENT_POINTS=2,3,5,8,13          # 对应窗口最大浮盈回撤阈值
MIN_PROFIT_POINTS=3,4,7,11,18                 # 达到回撤止盈时的最小盈利

# 持仓管理
MAX_HOLDING_CANDLES=60                        # 最大持仓K线数
COOLING_CANDLES=3                             # 平仓后冷却期K线数

# 杠杆和资金管理
DEFAULT_LEVERAGE=20                           # 默认杠杆倍数
MAX_LEVERAGE=125                              # 最大杠杆倍数（根据OKX限制）
ORDER_FUND_RATIO=0.25                         # 单次开仓占用账户USDT比例
MAX_POSITION_VALUE=0.8                        # 最大持仓价值占账户比例

#################################################
# 5. 云备份配置
#################################################

# 备份目标（支持多种云存储）
BACKUP_PROVIDER=oss                           # 备份提供商：oss(阿里云)、cos(腾讯云)、s3(亚马逊)
BACKUP_BUCKET=your-backup-bucket              # 存储桶名称
BACKUP_PREFIX=rsi-tracker/                    # 存储路径前缀

# 阿里云OSS配置
OSS_ACCESS_KEY=your_oss_access_key            # 阿里云OSS访问密钥
OSS_SECRET_KEY=your_oss_secret_key            # 阿里云OSS访问密钥
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com     # 阿里云OSS终端节点

# 备份计划
BACKUP_CRON=0 3 * * *                         # 每天凌晨3点执行备份(cron格式)
BACKUP_RETENTION=30                           # 云端备份保留天数

#################################################
# 6. 系统运行参数
#################################################

# Web服务配置
WEB_HOST=0.0.0.0                              # Web服务监听地址
WEB_PORT=8080                                 # Web服务监听端口
API_PREFIX=/api/v1                            # API路径前缀
DEBUG_MODE=false                              # 调试模式开关

# Celery任务队列配置
CELERY_BROKER_URL=${REDIS_URL}                # Celery消息代理URL
CELERY_RESULT_BACKEND=${REDIS_URL}            # Celery结果后端URL
CELERY_TASK_ALWAYS_EAGER=false                # 是否立即执行任务（调试用）

# 日志配置
LOG_LEVEL=INFO                                # 日志级别(DEBUG, INFO, WARNING, ERROR)
LOG_FORMAT=json                               # 日志格式(json, text)
LOG_FILE=/app/logs/app.log                    # 日志文件路径

# 行情数据配置
KLINE_INTERVAL=1m                             # K线时间间隔(1m = 1分钟)
SYMBOL=ETH-USDT-SWAP                          # 交易对

#################################################
# 7. 安全相关配置
#################################################

# JWT认证配置
JWT_SECRET=your_very_long_random_secret_key   # JWT密钥，生产环境使用随机生成的长密钥
JWT_ALGORITHM=HS256                           # JWT算法
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440          # JWT访问令牌过期时间(分钟)

# Web安全配置
CORS_ORIGINS=http://localhost:3000,http://localhost:8080  # CORS允许的源
ALLOWED_HOSTS=localhost,127.0.0.1             # 允许的主机名
RATE_LIMIT=100                                # API速率限制(每分钟请求数)

# 加密配置
ENCRYPTION_KEY=your_32byte_encryption_key     # 用于加密敏感数据的密钥

# IP白名单（逗号分隔，留空表示允许所有IP）
IP_WHITELIST=                                 # 允许访问的IP白名单

# 告警通知
ENABLE_NOTIFICATIONS=true                     # 是否启用通知
NOTIFICATION_WEBHOOK=                         # 通知Webhook URL（支持钉钉/企业微信/Slack等）
NOTIFICATION_EMAIL=                           # 告警邮箱地址
