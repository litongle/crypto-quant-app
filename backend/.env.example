# 币钱袋量化交易后端 - 环境配置示例
# 首次启动无需此文件，访问 /web/setup 通过安装向导自动生成

# 应用配置
APP_NAME="CryptoQuant"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# 安装状态（安装向导完成后自动设为 true）
SETUP_COMPLETE=false

# 安全密钥（安装向导自动生成，请勿手动填写占位值）
SECRET_KEY=
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256

# 数据库配置（默认 SQLite，安装向导可选 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///./data/crypto_quant.db

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# Token 过期时间
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS 配置
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# 交易所 API 配置 (可选)
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret
OKX_API_KEY=your-okx-api-key
OKX_API_SECRET=your-okx-api-secret
OKX_PASSPHRASE=your-okx-passphrase
